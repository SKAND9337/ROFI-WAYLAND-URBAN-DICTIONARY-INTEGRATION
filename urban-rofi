#!/usr/bin/env python3

from __future__ import annotations

import subprocess
import sys
import textwrap
from pathlib import Path
from typing import Any, Dict, List, Optional

import requests

API = "https://api.urbandictionary.com/v0/define"
PAGE_SIZE = 5
MAX_HISTORY = 200
REQUEST_HEADERS = {"User-Agent": "urban-rofi/1.1"}

SEARCH_ROFI = ["rofi", "-dmenu", "-i", "-no-custom", "-matching", "fuzzy"]
RESULT_ROFI = ["rofi", "-dmenu", "-i", "-no-custom", "-matching", "fuzzy"]

HISTORY_FILE = Path.home() / ".local" / "share" / "urban-rofi" / "history.txt"


def run_rofi(prompt: str, items: List[str], cmd: List[str], allow_custom: bool = False) -> Optional[str]:
    rofi_cmd = cmd[:]
    if allow_custom and "-no-custom" in rofi_cmd:
        rofi_cmd.remove("-no-custom")

    try:
        proc = subprocess.run(
            rofi_cmd + ["-p", prompt],
            input="\n".join(items),
            text=True,
            capture_output=True,
        )
    except FileNotFoundError:
        show_message("rofi is not installed or is not available in PATH.")
        return None

    choice = proc.stdout.strip()
    return choice or None


def run_rofi_index(prompt: str, items: List[str], cmd: List[str]) -> Optional[int]:
    rofi_cmd = cmd[:]
    if "-format" not in rofi_cmd:
        rofi_cmd.extend(["-format", "i"])

    try:
        proc = subprocess.run(
            rofi_cmd + ["-p", prompt],
            input="\n".join(items),
            text=True,
            capture_output=True,
        )
    except FileNotFoundError:
        show_message("rofi is not installed or is not available in PATH.")
        return None

    choice = proc.stdout.strip()
    if not choice:
        return None

    try:
        idx = int(choice)
    except ValueError:
        return None

    return idx if 0 <= idx < len(items) else None


def show_message(message: str) -> None:
    # Forces a solid dark background and bright text for readability
    theme_override = (
        "window { width: 900px; background-color: #111111DD; border: 3px; border-color: #ff276c; padding: 10px; }"
        "mainbox { background-color: transparent; }"
        "textbox { text-color: #eae940; background-color: transparent; }"
    )

    try:
        subprocess.run(
            ["rofi", "-theme-str", theme_override, "-e", message],
            text=True,
            capture_output=True,
        )
    except FileNotFoundError:
        print(message, file=sys.stderr)


def normalize(text: str) -> str:
    return " ".join(text.split()).strip()


def as_text(value: Any) -> str:
    return normalize(value) if isinstance(value, str) else ""


def clean_urban_text(value: Any) -> str:
    return as_text(value).replace("[", "").replace("]", "")


def load_history() -> List[str]:
    if not HISTORY_FILE.exists():
        return []

    try:
        lines = HISTORY_FILE.read_text(encoding="utf-8", errors="replace").splitlines()
    except Exception:
        return []

    seen = set()
    history: List[str] = []

    for line in lines[::-1]:
        term = normalize(line)
        if not term:
            continue
        key = term.casefold()
        if key in seen:
            continue
        seen.add(key)
        history.append(term)

    return history


def save_history(term: str) -> None:
    term = normalize(term)
    if not term:
        return

    HISTORY_FILE.parent.mkdir(parents=True, exist_ok=True)

    history = load_history()
    key = term.casefold()
    history = [item for item in history if item.casefold() != key]
    history.insert(0, term)
    history = history[:MAX_HISTORY]

    try:
        HISTORY_FILE.write_text("\n".join(history) + "\n", encoding="utf-8")
    except Exception:
        # History should never break the dictionary lookup
        pass


def fetch_entries(term: str) -> List[Dict[str, Any]]:
    try:
        resp = requests.get(API, params={"term": term}, headers=REQUEST_HEADERS, timeout=10)
        resp.raise_for_status()
        data = resp.json()
    except requests.HTTPError as exc:
        status = exc.response.status_code if exc.response is not None else "unknown"
        show_message(f"Urban Dictionary API error ({status}):\n\n{exc}")
        return []
    except ValueError as exc:
        show_message(f"Failed to parse Urban Dictionary response:\n\n{exc}")
        return []
    except Exception as exc:
        show_message(f"Failed to fetch definition:\n\n{exc}")
        return []

    entries = data.get("list", [])
    if not isinstance(entries, list):
        return []

    return entries


def get_year(entry: Dict[str, Any]) -> str:
    # Safely extract the 4-digit year from the ISO date string
    date_str = as_text(entry.get("written_on"))
    if len(date_str) >= 4 and date_str[:4].isdigit():
        return date_str[:4]
    return "????"


def preview(entry: Dict[str, Any], width: int = 110) -> str:
    definition = clean_urban_text(entry.get("definition"))
    if not definition:
        return "(no definition)"
    return textwrap.shorten(definition, width=width, placeholder="...")


def format_list_item(entry: Dict[str, Any]) -> str:
    year = get_year(entry)
    prev_text = preview(entry, width=65)
    thumbs_up = entry.get("thumbs_up")
    score = f" | +{thumbs_up}" if isinstance(thumbs_up, int) else ""
    return f"{prev_text:<55} | 📅 {year}{score}"


def format_detail(entry: Dict[str, Any]) -> str:
    word = as_text(entry.get("word")) or "(unknown)"

    full_date = as_text(entry.get("written_on")).split("T")[0]
    date_display = f"📅 Written: {full_date}" if full_date else ""

    definition = clean_urban_text(entry.get("definition"))
    example = clean_urban_text(entry.get("example"))
    author = as_text(entry.get("author"))
    permalink = as_text(entry.get("permalink"))
    thumbs_up = entry.get("thumbs_up")
    thumbs_down = entry.get("thumbs_down")

    parts = [
        word,
        "",
    ]

    if date_display:
        parts.append(date_display)
        parts.append("")

    if isinstance(thumbs_up, int) or isinstance(thumbs_down, int):
        up = thumbs_up if isinstance(thumbs_up, int) else "?"
        down = thumbs_down if isinstance(thumbs_down, int) else "?"
        parts.extend([f"Votes: +{up} / -{down}", ""])

    parts.extend(
        [
            "Definition:",
            textwrap.fill(definition or "(no definition)", width=72),
        ]
    )

    if example:
        parts += [
            "",
            "Example:",
            textwrap.fill(example, width=72),
        ]

    if author:
        parts += [
            "",
            f"Author: {author}",
        ]

    if permalink:
        parts += [
            "",
            permalink,
        ]

    return "\n".join(parts)


def page_items(entries: List[Dict[str, Any]], page: int) -> List[str]:
    start = page * PAGE_SIZE
    end = start + PAGE_SIZE
    chunk = entries[start:end]

    items = [format_list_item(e) for e in chunk]

    if page > 0:
        items.append("◀ Previous page")
    if end < len(entries):
        items.append("Next page ▶")

    return items


def total_pages(item_count: int) -> int:
    return max(1, (item_count + PAGE_SIZE - 1) // PAGE_SIZE)


def choose_term() -> Optional[str]:
    if len(sys.argv) > 1:
        return normalize(" ".join(sys.argv[1:]))

    history = load_history()
    items = history[:]

    choice = run_rofi("Urban Dictionary", items, SEARCH_ROFI, allow_custom=True)
    return normalize(choice) if choice else None


def main() -> int:
    term = choose_term()
    if not term:
        return 0

    save_history(term)

    entries = fetch_entries(term)
    if not entries:
        show_message(f"No results found for:\n\n{term}")
        return 0

    page = 0

    while True:
        items = page_items(entries, page)
        choice_idx = run_rofi_index(
            f"Urban Dictionary ({page + 1}/{total_pages(len(entries))})",
            items,
            RESULT_ROFI,
        )
        if choice_idx is None:
            return 0

        start = page * PAGE_SIZE
        end = start + PAGE_SIZE
        chunk = entries[start:end]
        nav_idx = len(chunk)

        if page > 0 and choice_idx == nav_idx:
            page = max(0, page - 1)
            continue

        if end < len(entries) and choice_idx == nav_idx + (1 if page > 0 else 0):
            if end < len(entries):
                page += 1
            continue

        if choice_idx >= len(chunk):
            return 0

        show_message(format_detail(chunk[choice_idx]))
        return 0


if __name__ == "__main__":
    raise SystemExit(main())
